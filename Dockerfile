# 1. Берем официальный образ Python (легкая версия)
FROM python:3.10-slim

# 2. Указываем рабочую папку внутри контейнера
WORKDIR /app

# 3. Копируем файл со списком библиотек в контейнер
COPY requirements.txt .

# 4. Устанавливаем эти библиотеки
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копируем все остальные файлы твоего проекта (код бота)
COPY . .

# 6. Команда, которая запустит бота при старте контейнера
# Замени 'app.py' на название твоего главного файла
CMD ["python", "app.py"]